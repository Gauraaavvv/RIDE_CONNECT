# Production Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Configuration - Replace with your actual MongoDB URI
MONGODB_URI=YOUR_MONGO_URI

# JWT Configuration - Replace with a strong secret key
JWT_SECRET=YOUR_SECRET

# CORS Origins - Replace with your actual frontend URL
CORS_ORIGINS=https://client-cyan-rho-21.vercel.app

# Google Maps API Key - Replace with your actual API key
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
